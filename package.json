{
  "name": "depshield-mcp",
  "version": "0.1.0",
  "type": "module",
  "description": "MCP server for real-time dependency security — checks packages against CVE databases before your AI coding agent installs them. Works with Cursor, Claude Code, Windsurf, and any MCP-compatible IDE.",
  "main": "dist/index.js",
  "bin": {
    "depshield-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cursor",
    "claude-code",
    "windsurf",
    "antigravity",
    "security",
    "dependencies",
    "vulnerability",
    "osv",
    "npm",
    "pypi",
    "supply-chain",
    "ai-agent",
    "code-assistant",
    "vibe-coding"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/devanshkaria88/depshield-mcp"
  },
  "homepage": "https://github.com/devanshkaria88/depshield-mcp#readme",
  "bugs": {
    "url": "https://github.com/devanshkaria88/depshield-mcp/issues"
  },
  "author": "Devansh Karia",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    ".cursor"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
